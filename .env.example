# Root .env.example — values shared across packages.
# Per-package .env.example files live in apps/web, apps/worker, packages/db.

# Copy to .env in each location that needs it. NEVER commit .env files.
# The .gitignore already blocks .env / .env.local / .env.*.local.

# Postgres (Supabase / Neon / local with pgvector)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eventsnap

# Redis for the job queue
REDIS_URL=redis://localhost:6379
