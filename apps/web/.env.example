# Copy to .env.local for local dev. Never commit .env.local.

# Database (Supabase / Neon / local Postgres with pgvector)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eventsnap

# Auth.js
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Phone OTP via MSG91 (https://msg91.com)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=eventsnap-photos
R2_PUBLIC_URL=

# Redis for job queue (Upstash or local)
REDIS_URL=redis://localhost:6379
