# Copy to .env.local for local dev. Never commit .env.local.

# Database (Postgres + pgvector — local Docker default)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eventsnap

# Auth.js v5 — REQUIRED in dev
# Generate with: openssl rand -base64 32   (or any random 32+ byte string)
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Auth.js trusts the host header in dev; set this to true if running behind a proxy.
AUTH_TRUST_HOST=true

# Google OAuth — fill these in from https://console.cloud.google.com when ready.
# Credentials (email+password) works without these.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Phone OTP via MSG91 — Phase 2.
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=
# MSG91_SENDER_ID=

# Cloudflare R2 — Phase 4.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=eventsnap-photos
# R2_PUBLIC_URL=

# Redis for job queue (local Docker default)
REDIS_URL=redis://localhost:6379
