# Copy to .env for local dev. Never commit .env.

DATABASE_URL=postgres://postgres:postgres@localhost:5432/eventsnap
REDIS_URL=redis://localhost:6379

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=eventsnap-photos

# Face matching: cosine distance threshold (lower = stricter)
FACE_MATCH_THRESHOLD=0.40

# InsightFace model cache dir
INSIGHTFACE_HOME=./.models

LOG_LEVEL=INFO
